{
  "info": {
    "_postman_id": "7b8a3f6d-6d7a-4d2d-8c13-36de74a91a20",
    "name": "Inventory API",
    "description": "Simple collection for testing the Inventory API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "product_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('product_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-001\",\n  \"name\": \"Keyboard\",\n  \"description\": \"Mechanical keyboard\",\n  \"price\": 1200,\n  \"stock_quantity\": 15,\n  \"low_stock_threshold\": 5,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            }
          }
        },
        {
          "name": "Show Product",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-001\",\n  \"name\": \"Keyboard Updated\",\n  \"description\": \"Updated description\",\n  \"price\": 1300,\n  \"stock_quantity\": 18,\n  \"low_stock_threshold\": 5,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            }
          }
        },
        {
          "name": "Increment Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"increment\",\n  \"quantity\": 3\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}/stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}",
                "stock"
              ]
            }
          }
        },
        {
          "name": "Decrement Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"decrement\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}/stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}",
                "stock"
              ]
            }
          }
        },
        {
          "name": "Low Stock Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/low-stock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "low-stock"
              ]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "{{product_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
